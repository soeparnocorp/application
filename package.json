{
  "name": "application",
  "description": "Application OpenAuth server, deploy in Cloudflare Pages _worker.ts",
  "private": true,
  "dependencies": {
    "@openauthjs/openauth": "0.4.3",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "wrangler": "4.56.0",
    "@cloudflare/workers-types": "^4.20250101.0"
  },
  "scripts": {
    "cf-typegen": "wrangler types",
    "check": "tsc && wrangler pages deploy . --dry-run",
    "deploy": "wrangler pages deploy .",
    "dev": "wrangler pages dev .",
    "predeploy": "wrangler d1 migrations apply APPLICATION_DB --remote",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  }
}
